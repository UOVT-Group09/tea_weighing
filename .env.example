# ---------------------------------------------------------------------------
# Tea Leaves Weighing & Smart Records System — environment configuration
# Owner: H.G.P.C. Sagara (PM & Integration Dev)
#
# Copy this file to ".env" and fill in real values. Never commit ".env".
#   cp .env.example .env
# ---------------------------------------------------------------------------

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# MySQL connection (matches the schema in src/models.py)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tea_weighing
DB_USER=root
DB_PASSWORD=1234

# Default operator account, created automatically on first run if the
# operator table is empty. Change the password before any real deployment.
DEFAULT_OPERATOR_USERNAME=admin
DEFAULT_OPERATOR_PASSWORD=admin123
